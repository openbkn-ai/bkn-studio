# Keep the build context lean and never bake host state / secrets into the image.
.git
.github
node_modules
**/node_modules
dist
tests/e2e
tests/execution-factory
tests/**/node_modules

# Local env may hold dev tokens (VITE_DEV_ACCESS_TOKEN) — must not enter the image.
.env
.env.*
!.env.example

*.log
.DS_Store
.vscode
.idea
